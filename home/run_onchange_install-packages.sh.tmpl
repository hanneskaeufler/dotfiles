{{ if eq .chezmoi.os "linux" -}}
#!/bin/sh
echo "Installing on linux ..."
{{ else if eq .chezmoi.os "darwin" -}}
#!/bin/sh
echo "Installing on macos ..."
brew install \
  tmux \
  neovim zsh-vi-mode fzf ripgrep stylua \
  git git-lfs \
  uv \
  jq \
  gh \
  copilot-cli anomalyco/tap/opencode \
  bazelisk
{{ if .use_rust -}}
brew install rustup
rustup toolchain install stable
rustup default stable
{{ end -}}
{{ if .use_aws -}}
brew install awscli kubectl helm k9s node go
{{ end -}}
{{ end -}}
